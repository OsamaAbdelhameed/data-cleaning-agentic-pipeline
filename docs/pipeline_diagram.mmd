config:
  flowchart:
    curve: linear
---
graph TD;
	__start__([<p>__start__</p>]):::first
	load(load)
	schema_validate(schema_validate)
	security_on_healing(security_on_healing)
	fixer(fixer)
	quarantine_remaining(quarantine_remaining)
	date_normalize(date_normalize)
	security_gate(security_gate)
	__end__([<p>__end__</p>]):::last
	__start__ --> load;
	date_normalize --> security_gate;
	fixer --> schema_validate;
	load --> schema_validate;
	quarantine_remaining --> date_normalize;
	schema_validate -.-> date_normalize;
	schema_validate -.-> quarantine_remaining;
	schema_validate -.-> security_on_healing;
	security_on_healing --> fixer;
	security_gate --> __end__;
	classDef default fill:#f2f0ff,line-height:1.2
	classDef first fill-opacity:0
	classDef last fill:#bfb6fc
